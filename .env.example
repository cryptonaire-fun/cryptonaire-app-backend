# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/cryptonaire

# JWT
JWT_SECRET=your-strong-random-secret-here
JWT_EXPIRES_IN=7d

# Groq
GROQ_API_KEY=your-groq-api-key-here

# Solana (devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com
# JSON array of the treasury keypair bytes — generated by scripts/setup-devnet-mint.ts
TREASURY_PRIVATE_KEY=[1,2,3,...]
# SPL token mint address — printed by scripts/setup-devnet-mint.ts
SKR_MINT_ADDRESS=your-devnet-mint-address-here
